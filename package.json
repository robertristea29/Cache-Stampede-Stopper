{
  "name": "cache-stampede-stopper",
  "version": "1.0.0",
  "description": "This repository is created for my first Flavour Project in semester 6. It refers refers to the technical solution you are building to prevent a system-wide failure known as a Cache Stampede (or the \"Thundering Herd\" problem).",
  "main": "index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "worker": "ts-node src/worker.ts",
    "worker:dev": "nodemon --exec ts-node src/worker.ts",
    "build": "tsc",
    "test:scenario": "ts-node src/test-scenarios.ts",
    "test:home": "ts-node src/test-scenarios.ts 1",
    "test:away": "ts-node src/test-scenarios.ts 2",
    "test:reset": "ts-node src/test-scenarios.ts 3",
    "test:rapid-fire": "ts-node src/test-scenarios.ts 4",
    "test:backforth": "ts-node src/test-scenarios.ts 5",
    "test:wt-home": "ts-node src/test-scenarios-write-through.ts 1",
    "test:wt-away": "ts-node src/test-scenarios-write-through.ts 2",
    "test:wt-reset": "ts-node src/test-scenarios-write-through.ts 3",
    "test:wt-rapid-fire": "ts-node src/test-scenarios-write-through.ts 4",
    "test:wt-backforth": "ts-node src/test-scenarios-write-through.ts 5",
    "test:comparison": "ts-node src/comparison-test.ts",
    "load-test": "k6 run --out prometheus=http://prometheus:9090/api/v1/write load-test-comparison.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.0",
    "pg": "^8.19.0"
  }
}
